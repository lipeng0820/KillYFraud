{
  "manifest_version": 3,
  "name": "X 垃圾私信斩杀器",
  "version": "1.0.1",
  "description": "Auto report and block spam direct messages on X.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://*.x.com/*", "*://*.twitter.com/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
